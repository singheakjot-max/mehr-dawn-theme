{%- comment -%} MEHR brand homepage. Inter 500 / -0.04em headlines, Instrument Serif italic kickers, pastel + lime + ink. {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- liquid
  assign p_bpc = all_products['test']
  assign p_natto = all_products['mehr-ultimate-nattokinase-natural-solution-for-reversing-arterial-inflammation']
-%}

<style>
  #MehrHome-{{ section.id }} {
    --mehr-bg: #FAFAF7; --mehr-ink: #0F0F0E; --mehr-muted: #6B6B66; --mehr-line: #E8E6DF;
    --mehr-accent: #DCE94B; --mehr-product: #1E3A8A; --mehr-product-hero: #DCE7F5; --mehr-success: #2F7A3E;
  }
  .mehr-home { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; color: var(--mehr-ink); background: var(--mehr-bg); line-height: 1.5; -webkit-font-smoothing: antialiased; }
  .mehr-home *, .mehr-home *::before, .mehr-home *::after { box-sizing: border-box; }
  .mehr-home img { display: block; max-width: 100%; }
  .mehr-home .mh-wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
  .mehr-home .mh-wrap--narrow { max-width: 760px; }
  @media (min-width:1024px){ .mehr-home .mh-wrap { padding: 0 32px; } }
  .mehr-home .mh-section { padding: 72px 0; }
  @media (min-width:1024px){ .mehr-home .mh-section { padding: 104px 0; } }
  .mehr-home .mh-center { text-align: center; }

  .mehr-home .mh-kicker { font-family: 'Instrument Serif', serif; font-style: italic; color: var(--mehr-muted); font-size: clamp(20px, 2.4vw, 30px); line-height: 1.1; margin: 0 0 10px; }
  .mehr-home .mh-headline { font-family: 'Inter', sans-serif; font-weight: 500; letter-spacing: -0.04em; line-height: 0.96; font-size: clamp(40px, 7vw, 86px); margin: 0; }
  .mehr-home .mh-headline em, .mehr-home .mh-title em { font-family: 'Instrument Serif', serif; font-style: italic; font-weight: 400; letter-spacing: 0; }
  .mehr-home .mh-title { font-family: 'Inter', sans-serif; font-weight: 500; letter-spacing: -0.04em; line-height: 0.98; font-size: clamp(34px, 5vw, 60px); margin: 0 0 16px; }
  .mehr-home .mh-section__kicker { font-family: 'Instrument Serif', serif; font-style: italic; color: var(--mehr-muted); font-size: clamp(20px, 2.2vw, 28px); margin: 0 0 8px; }
  .mehr-home .mh-lede { font-size: clamp(16px,1.4vw,19px); line-height: 1.6; color: var(--mehr-ink); }
  .mehr-home .mh-muted { color: var(--mehr-muted); }

  .mehr-home .mh-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; background: var(--mehr-ink); color: #fff; border: 0; border-radius: 999px; padding: 16px 32px; font-weight: 500; font-size: 16px; text-decoration: none; transition: background .15s, transform .15s; }
  .mehr-home .mh-btn:hover { background: #222; transform: translateY(-1px); }
  .mehr-home .mh-link { display: inline-flex; align-items: center; gap: 6px; color: var(--mehr-ink); text-decoration: none; font-weight: 500; font-size: 15px; border-bottom: 1px solid var(--mehr-ink); padding-bottom: 2px; }
  .mehr-home .mh-link:hover { opacity: .6; }
  .mehr-home .mh-chip { display: inline-block; background: var(--mehr-accent); color: var(--mehr-ink); border-radius: 999px; padding: 5px 12px; font-size: 12px; font-weight: 600; }

  .mehr-home .mh-announce { background: #F1EFE8; padding: 10px 16px; }
  .mehr-home .mh-announce__inner { max-width: 1180px; margin: 0 auto; display: flex; gap: 12px; align-items: center; justify-content: center; font-size: 14px; flex-wrap: wrap; }
  .mehr-home .mh-announce__text { font-weight: 500; }

  /* Hero */
  .mehr-home .mh-hero { background: var(--mehr-product-hero); }
  .mehr-home .mh-hero__inner { max-width: 900px; margin: 0 auto; padding: 88px 24px; text-align: center; }
  @media (min-width:1024px){ .mehr-home .mh-hero__inner { padding: 132px 24px; } }
  .mehr-home .mh-hero .mh-lede { max-width: 38em; margin: 22px auto 0; }
  .mehr-home .mh-cta-row { display: flex; gap: 20px; align-items: center; justify-content: center; flex-wrap: wrap; margin-top: 34px; }

  /* Pillars */
  .mehr-home .mh-pillars { display: grid; grid-template-columns: 1fr; gap: 28px; margin-top: 40px; }
  @media (min-width:768px){ .mehr-home .mh-pillars { grid-template-columns: repeat(2,1fr); gap: 40px 48px; } }
  @media (min-width:1024px){ .mehr-home .mh-pillars { grid-template-columns: repeat(4,1fr); } }
  .mehr-home .mh-pillar__icon { color: var(--mehr-product); margin-bottom: 14px; }
  .mehr-home .mh-pillar__icon svg { width: 30px; height: 30px; }
  .mehr-home .mh-pillar h3 { font-family: 'Inter', sans-serif; font-weight: 500; letter-spacing: -0.02em; font-size: 19px; margin: 0 0 8px; }
  .mehr-home .mh-pillar p { margin: 0; color: var(--mehr-muted); font-size: 15px; line-height: 1.55; }

  /* Purpose band */
  .mehr-home .mh-purpose { background: var(--mehr-ink); color: #fff; }
  .mehr-home .mh-purpose__inner { max-width: 920px; margin: 0 auto; padding: 88px 24px; text-align: center; }
  @media (min-width:1024px){ .mehr-home .mh-purpose__inner { padding: 120px 24px; } }
  .mehr-home .mh-purpose__kicker { font-family: 'Instrument Serif', serif; font-style: italic; color: var(--mehr-accent); font-size: 24px; margin: 0 0 18px; }
  .mehr-home .mh-purpose__text { font-family: 'Inter', sans-serif; font-weight: 500; letter-spacing: -0.03em; line-height: 1.15; font-size: clamp(28px, 4vw, 52px); margin: 0; }
  .mehr-home .mh-purpose__text em { font-family: 'Instrument Serif', serif; font-style: italic; color: var(--mehr-accent); }

  /* Lineup */
  .mehr-home .mh-lineup { display: grid; grid-template-columns: 1fr; gap: 24px; margin-top: 40px; }
  @media (min-width:768px){ .mehr-home .mh-lineup { grid-template-columns: 1fr 1fr; } }
  .mehr-home .mh-card { display: flex; flex-direction: column; border: 1px solid var(--mehr-line); border-radius: 20px; overflow: hidden; background: #fff; text-decoration: none; color: var(--mehr-ink); transition: transform .15s, box-shadow .15s; }
  .mehr-home .mh-card:hover { transform: translateY(-3px); box-shadow: 0 14px 40px rgba(15,15,14,.08); }
  .mehr-home .mh-card__media { aspect-ratio: 4 / 3; background: var(--mehr-product-hero); display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .mehr-home .mh-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .mehr-home .mh-card--natto .mh-card__media { background: #F4E7EA; }
  .mehr-home .mh-card__body { padding: 24px 26px 28px; }
  .mehr-home .mh-card__eyebrow { font-size: 13px; color: var(--mehr-muted); margin: 0 0 4px; }
  .mehr-home .mh-card__title { font-family: 'Inter', sans-serif; font-weight: 500; letter-spacing: -0.03em; font-size: 26px; margin: 0 0 8px; }
  .mehr-home .mh-card__desc { margin: 0 0 16px; color: var(--mehr-muted); font-size: 15px; line-height: 1.55; }
  .mehr-home .mh-card__cta { display: inline-flex; align-items: center; gap: 6px; font-weight: 500; font-size: 15px; border-bottom: 1px solid var(--mehr-ink); padding-bottom: 2px; }

  /* Standards strip */
  .mehr-home .mh-standards { border-top: 1px solid var(--mehr-line); border-bottom: 1px solid var(--mehr-line); }
  .mehr-home .mh-standards__grid { display: grid; grid-template-columns: repeat(2,1fr); }
  @media (min-width:768px){ .mehr-home .mh-standards__grid { grid-template-columns: repeat(4,1fr); } }
  .mehr-home .mh-standards__item { display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center; padding: 30px 16px; }
  .mehr-home .mh-standards__item svg { width: 24px; height: 24px; color: var(--mehr-product); }
  .mehr-home .mh-standards__item p { margin: 0; font-size: 13px; font-weight: 500; }
  @media (min-width:768px){ .mehr-home .mh-standards__item + .mh-standards__item { border-left: 1px solid var(--mehr-line); } }

  /* Founder note */
  .mehr-home .mh-founder { max-width: 720px; margin: 0 auto; text-align: center; }
  .mehr-home .mh-founder__quote { font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(22px, 3vw, 34px); line-height: 1.3; margin: 0 0 20px; color: var(--mehr-ink); }
  .mehr-home .mh-founder__by { font-size: 14px; color: var(--mehr-muted); }

  /* Capture */
  .mehr-home .mh-capture { background: var(--mehr-ink); color: #fff; }
  .mehr-home .mh-capture__inner { max-width: 1180px; margin: 0 auto; padding: 64px 24px; display: grid; grid-template-columns: 1fr; gap: 28px; align-items: center; }
  @media (min-width:900px){ .mehr-home .mh-capture__inner { grid-template-columns: 1fr 1fr; padding: 80px 56px; } }
  .mehr-home .mh-capture__title { font-family: 'Inter', sans-serif; font-weight: 500; letter-spacing: -0.03em; font-size: clamp(28px, 3.4vw, 44px); line-height: 1; margin: 0; color: #fff; }
  .mehr-home .mh-capture__note { margin: 14px 0 0; color: rgba(255,255,255,.7); font-size: 15px; }
  .mehr-home .mh-capture form { display: flex; border: 1px solid rgba(255,255,255,.35); border-radius: 999px; overflow: hidden; background: rgba(255,255,255,.04); }
  .mehr-home .mh-capture input[type=email] { flex: 1; background: transparent; border: 0; color: #fff; padding: 16px 22px; font-size: 15px; font-family: 'Inter', sans-serif; outline: none; }
  .mehr-home .mh-capture input[type=email]::placeholder { color: rgba(255,255,255,.5); }
  .mehr-home .mh-capture button { background: var(--mehr-accent); color: var(--mehr-ink); border: 0; padding: 0 28px; font-weight: 600; font-size: 15px; cursor: pointer; font-family: 'Inter', sans-serif; }
  .mehr-home .mh-capture__success { margin: 14px 0 0; color: var(--mehr-accent); font-weight: 500; }
  .mehr-home .mh-disclaimer { font-size: 12px; color: var(--mehr-muted); text-align: center; max-width: 720px; margin: 0 auto; padding: 0 24px 56px; line-height: 1.5; }

  /* === Image placeholder slots (drop real assets in later) === */
  .mehr-home .mh-ph { position: relative; display: flex; align-items: center; justify-content: center; text-align: center; background: repeating-linear-gradient(45deg, #F1EFE8, #F1EFE8 11px, #ECEAE2 11px, #ECEAE2 22px); border: 1.5px dashed #C7C4B9; border-radius: 16px; color: var(--mehr-muted); min-height: 200px; padding: 24px; }
  .mehr-home .mh-ph__label { font-size: 13px; line-height: 1.45; max-width: 26em; }
  .mehr-home .mh-ph__label b { display: block; font-family: 'Instrument Serif', serif; font-style: italic; font-weight: 400; font-size: 19px; color: var(--mehr-ink); margin-bottom: 4px; }
  .mehr-home .mh-ph--wide { min-height: 300px; border-radius: 22px; }
  @media (min-width:1024px){ .mehr-home .mh-ph--wide { min-height: 420px; } }
  .mehr-home .mh-ph--tall { height: 100%; min-height: 280px; }
  .mehr-home .mh-ph--avatar { width: 50px; height: 50px; min-height: 0; border-radius: 999px; padding: 0; flex: 0 0 auto; }

  /* Who-we-are split */
  .mehr-home .mh-split { display: grid; grid-template-columns: 1fr; gap: 36px; align-items: center; }
  @media (min-width:900px){ .mehr-home .mh-split { grid-template-columns: 1.05fr 1fr; gap: 56px; } }

  /* Science / evidence band */
  .mehr-home .mh-science-grid { display: grid; grid-template-columns: 1fr; gap: 24px; margin-top: 40px; }
  @media (min-width:768px){ .mehr-home .mh-science-grid { grid-template-columns: 1fr 1fr; } }

  /* Reviews + transformations */
  .mehr-home .mh-reviews { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 40px; }
  @media (min-width:768px){ .mehr-home .mh-reviews { grid-template-columns: repeat(3,1fr); } }
  .mehr-home .mh-review { border: 1px solid var(--mehr-line); border-radius: 18px; padding: 24px; background: #fff; }
  .mehr-home .mh-review__stars { color: var(--mehr-product); letter-spacing: 3px; font-size: 14px; }
  .mehr-home .mh-review__text { font-size: 15px; line-height: 1.55; color: var(--mehr-muted); margin: 12px 0 18px; }
  .mehr-home .mh-review__who { display: flex; align-items: center; gap: 12px; }
  .mehr-home .mh-review__name { font-size: 14px; font-weight: 500; }
  .mehr-home .mh-review__name span { display: block; font-weight: 400; color: var(--mehr-muted); font-size: 12px; }
  .mehr-home .mh-transform { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; margin-top: 28px; }
  @media (min-width:768px){ .mehr-home .mh-transform { grid-template-columns: repeat(4,1fr); } }
  .mehr-home .mh-transform .mh-ph { min-height: 220px; }
  .mehr-home .mh-founder__faces { display: flex; align-items: center; justify-content: center; gap: 10px; margin: 0 0 20px; }
</style>

<div class="mehr-home" id="MehrHome-{{ section.id }}">

  {%- if section.settings.show_announcement -%}
    <div class="mh-announce">
      <div class="mh-announce__inner">
        {%- if section.settings.announcement_chip != blank -%}<span class="mh-chip">{{ section.settings.announcement_chip }}</span>{%- endif -%}
        <span class="mh-announce__text">{{ section.settings.announcement_text }}</span>
        <span aria-hidden="true">→</span>
      </div>
    </div>
  {%- endif -%}

  <!-- BRAND HERO -->
  <section class="mh-hero">
    <div class="mh-hero__inner">
      <p class="mh-kicker">The foundational health company</p>
      <h1 class="mh-headline">More from the body <em>you already have</em></h1>
      <p class="mh-lede">MEHR makes daily, foundational supplements from the compounds your body already uses to repair itself — synthesised to pharmaceutical purity, delivered orally, and tested in the open. No needles. No fillers. No hype.</p>
      <div class="mh-cta-row">
        <a class="mh-btn" href="#mh-lineup">Shop the lineup</a>
        <a class="mh-link" href="#mh-story">Read our story →</a>
      </div>
    </div>
  </section>

  <!-- HERO LIFESTYLE IMAGE (placeholder) -->
  <section class="mh-section" style="padding:56px 0 0;">
    <div class="mh-wrap">
      <div class="mh-ph mh-ph--wide"><span class="mh-ph__label"><b>Hero lifestyle photo</b>Wide editorial shot — a real person in a calm morning routine with MEHR, natural light, lots of negative space. Suggested 1600×900.</span></div>
    </div>
  </section>

  <!-- WHO WE ARE (split with brand photo) -->
  <section class="mh-section" id="mh-story">
    <div class="mh-wrap">
      <div class="mh-split">
        <div>
          <p class="mh-section__kicker">Who we are</p>
          <h2 class="mh-title">We started with a simple frustration</h2>
          <p class="mh-lede mh-muted">The most promising recovery and longevity compounds were locked behind injections, grey-market vials, and zero transparency. MEHR exists to change that — to take what the research community already trusts and make it clean, oral, and easy to keep up every day. We name every ingredient, third-party test every batch, and refuse the fillers and proprietary blends the rest of the industry hides behind.</p>
        </div>
        <div class="mh-ph mh-ph--tall"><span class="mh-ph__label"><b>Brand / founder photo</b>Studio or lifestyle image that says who MEHR is — product flat-lay, lab bench, or founders. Portrait crop, ~900×1100.</span></div>
      </div>
    </div>
  </section>

  <!-- PILLARS -->
  <section class="mh-section" style="padding-top:0;">
    <div class="mh-wrap">
      <div class="mh-pillars">
        <div class="mh-pillar">
          <span class="mh-pillar__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c4 5 6 8 6 11a6 6 0 0 1-12 0c0-3 2-6 6-11z"/></svg></span>
          <h3>Pharmaceutical purity</h3>
          <p>Actives synthesised to 99.9% purity. No proprietary blends, no hiding behind ‘other ingredients.’</p>
        </div>
        <div class="mh-pillar">
          <span class="mh-pillar__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M10 3v6l-5 9a2 2 0 0 0 1.8 3h10.4a2 2 0 0 0 1.8-3l-5-9V3"/></svg></span>
          <h3>Radically transparent</h3>
          <p>Third-party tested, certificate of analysis on request, every ingredient named on the label.</p>
        </div>
        <div class="mh-pillar">
          <span class="mh-pillar__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19V5a2 2 0 0 1 2-2h9l5 5v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><path d="M8 8h6M8 12h8M8 16h5"/></svg></span>
          <h3>Research-backed</h3>
          <p>Every formula is built on published human and pre-clinical studies — and we link to them.</p>
        </div>
        <div class="mh-pillar">
          <span class="mh-pillar__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
          <h3>Oral &amp; daily</h3>
          <p>No needles, no fridge, no ritual. One capsule that fits the routine you already have.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PURPOSE -->
  <section class="mh-purpose">
    <div class="mh-purpose__inner">
      <p class="mh-purpose__kicker">Our purpose</p>
      <p class="mh-purpose__text">To make foundational health compounds clean, proven, and <em>effortless</em> — so taking care of your body stops being complicated.</p>
    </div>
  </section>

  <!-- LINEUP -->
  <section class="mh-section" id="mh-lineup">
    <div class="mh-wrap mh-center">
      <p class="mh-section__kicker">The lineup</p>
      <h2 class="mh-title">Two formulas. One standard.</h2>
    </div>
    <div class="mh-wrap">
      <div class="mh-lineup">
        <a class="mh-card" href="{{ p_bpc.url | default: '/products/test' }}">
          <div class="mh-card__media">
            {%- if p_bpc.featured_image != blank -%}<img src="{{ p_bpc.featured_image | image_url: width: 900 }}" alt="BPC 157" width="600" height="450" loading="lazy">{%- endif -%}
          </div>
          <div class="mh-card__body">
            <p class="mh-card__eyebrow">Recovery oral peptide</p>
            <h3 class="mh-card__title">BPC 157</h3>
            <p class="mh-card__desc">The body-protection peptide for gut, joints, tendons, muscle and sleep — now an oral capsule.</p>
            <span class="mh-card__cta">Shop BPC 157 →</span>
          </div>
        </a>
        <a class="mh-card mh-card--natto" href="{{ p_natto.url | default: '/products/mehr-ultimate-nattokinase-natural-solution-for-reversing-arterial-inflammation' }}">
          <div class="mh-card__media">
            {%- if p_natto.featured_image != blank -%}<img src="{{ p_natto.featured_image | image_url: width: 900 }}" alt="Ultimate Nattokinase" width="600" height="450" loading="lazy">{%- endif -%}
          </div>
          <div class="mh-card__body">
            <p class="mh-card__eyebrow">Cardiovascular enzyme</p>
            <h3 class="mh-card__title">Ultimate Nattokinase</h3>
            <p class="mh-card__desc">A clinically-studied fibrinolytic enzyme for healthy circulation, blood pressure and arterial health.</p>
            <span class="mh-card__cta">Shop Nattokinase →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- STANDARDS -->
  <div class="mh-standards">
    <div class="mh-wrap">
      <div class="mh-standards__grid">
        <div class="mh-standards__item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg><p>Third-party tested</p></div>
        <div class="mh-standards__item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21c5-3 8-7 8-12V5l-8-2-8 2v4c0 5 3 9 8 12z"/><path d="M12 7v8M8 11h8"/></svg><p>No fillers, ever</p></div>
        <div class="mh-standards__item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8.5 12l2.5 2.5 4.5-5"/></svg><p>Made in the USA</p></div>
        <div class="mh-standards__item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h13v10H3zM16 10h4l1 3v4h-5"/><circle cx="7" cy="18" r="1.6"/><circle cx="18" cy="18" r="1.6"/></svg><p>Free U.S. shipping</p></div>
      </div>
    </div>
  </div>

  <!-- SCIENCE / EVIDENCE (placeholders) -->
  <section class="mh-section">
    <div class="mh-wrap">
      <div class="mh-center">
        <p class="mh-section__kicker">The science, in the open</p>
        <h2 class="mh-title">Proof you can actually see</h2>
      </div>
      <div class="mh-science-grid">
        <div class="mh-ph mh-ph--wide"><span class="mh-ph__label"><b>Mechanism illustration</b>Clean diagram of how the compounds work in the body (tissue repair / circulation). Brand colours, minimal line art.</span></div>
        <div class="mh-ph mh-ph--wide"><span class="mh-ph__label"><b>Certificate of Analysis</b>Photo or scan of a real third-party lab report / COA, with the 99.9% purity result visible.</span></div>
      </div>
    </div>
  </section>

  <!-- REVIEWS + TRANSFORMATIONS (placeholders) -->
  <section class="mh-section" style="padding-top:0;">
    <div class="mh-wrap">
      <div class="mh-center">
        <p class="mh-section__kicker">Real people, real results</p>
        <h2 class="mh-title">Loved by people who feel the difference</h2>
      </div>
      <div class="mh-reviews">
        <div class="mh-review">
          <div class="mh-review__stars">★★★★★</div>
          <p class="mh-review__text">[ Customer review copy — pull a real testimonial about recovery, gut, or joints here. ]</p>
          <div class="mh-review__who"><span class="mh-ph mh-ph--avatar"></span><span class="mh-review__name">[ Customer name ]<span>Verified buyer</span></span></div>
        </div>
        <div class="mh-review">
          <div class="mh-review__stars">★★★★★</div>
          <p class="mh-review__text">[ Customer review copy — a second real testimonial, ideally a different benefit/use case. ]</p>
          <div class="mh-review__who"><span class="mh-ph mh-ph--avatar"></span><span class="mh-review__name">[ Customer name ]<span>Verified buyer</span></span></div>
        </div>
        <div class="mh-review">
          <div class="mh-review__stars">★★★★★</div>
          <p class="mh-review__text">[ Customer review copy — a third real testimonial, e.g. sleep, energy, or daily ease. ]</p>
          <div class="mh-review__who"><span class="mh-ph mh-ph--avatar"></span><span class="mh-review__name">[ Customer name ]<span>Verified buyer</span></span></div>
        </div>
      </div>
      <div class="mh-transform">
        <div class="mh-ph"><span class="mh-ph__label"><b>Before</b>Day 0 transformation / progress photo or metric card.</span></div>
        <div class="mh-ph"><span class="mh-ph__label"><b>After</b>Result after a 60–90 day cycle.</span></div>
        <div class="mh-ph"><span class="mh-ph__label"><b>Before</b>Second customer, day 0.</span></div>
        <div class="mh-ph"><span class="mh-ph__label"><b>After</b>Second customer, after cycle.</span></div>
      </div>
    </div>
  </section>

  <!-- GOAL / VISION -->
  <section class="mh-section" style="padding-top:0;">
    <div class="mh-wrap mh-wrap--narrow mh-center">
      <p class="mh-section__kicker">Where we're going</p>
      <h2 class="mh-title">A foundational stack for the long run</h2>
      <p class="mh-lede mh-muted">We're building a small, deliberate set of clean, clinically-grounded daily formulas that cover the systems modern life wears down — recovery, circulation, resilience. Two products today. A complete foundation tomorrow. Every addition held to the same standard: pure, proven, and honest.</p>
    </div>
  </section>

  <!-- FOUNDER NOTE -->
  <section class="mh-section" style="padding-top:0;">
    <div class="mh-wrap">
      <div class="mh-founder">
        <div class="mh-founder__faces">
          <span class="mh-ph mh-ph--avatar"></span>
          <span class="mh-ph mh-ph--avatar"></span>
        </div>
        <p class="mh-founder__quote">“We only make things we'd take ourselves, every day — and we'll always show you exactly what's inside.”</p>
        <p class="mh-founder__by">— The MEHR team</p>
      </div>
    </div>
  </section>

  <!-- EMAIL CAPTURE -->
  <div class="mh-capture">
    <div class="mh-capture__inner">
      <div>
        <h2 class="mh-capture__title">{{ section.settings.capture_title | default: 'Get 10% off your first order' }}</h2>
        <p class="mh-capture__note">{{ section.settings.capture_note | default: 'Plus first access to new formulas and the research behind them.' }}</p>
      </div>
      <div>
        {%- form 'customer' -%}
          {%- if form.posted_successfully? -%}<p class="mh-capture__success">Thanks — your discount is on the way.</p>{%- endif -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="MehrCaptureEmail-{{ section.id }}">Email</label>
          <input id="MehrCaptureEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="Email address" required>
          <button type="submit">Sign Up</button>
        {%- endform -%}
      </div>
    </div>
  </div>

  <p class="mh-disclaimer">These statements have not been evaluated by the Food and Drug Administration. These products are not intended to diagnose, treat, cure, or prevent any disease.</p>

</div>

