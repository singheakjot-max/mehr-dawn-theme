    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announcement_chip", "label": "Chip", "default": "New" },
    { "type": "text", "id": "announcement_text", "label": "Text", "default": "Ultimate Nattokinase has landed — meet the lineup" },
    { "type": "product", "id": "hero_product", "label": "Hero product (optional)" },
    { "type": "header", "content": "Email Capture" },
    { "type": "text", "id": "capture_title", "label": "Title", "default": "Get 10% off your first order" },
    { "type": "text", "id": "capture_note", "label": "Note", "default": "Plus first access to new formulas and the research behind them." }
  ],
  "presets": [{ "name": "MEHR Home" }]
}
{% endschema %}