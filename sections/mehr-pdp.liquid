{{ 'mehr-pdp.css' | asset_url | stylesheet_tag }}
{{ 'mehr-pdp-gallery.css' | asset_url | stylesheet_tag }}
<script src="{{ 'mehr-pdp.js' | asset_url }}" defer="defer"></script>
{%- comment -%} Dawn's product-form custom element powers AJAX add-to-cart + cart drawer. It must be loaded here because this custom section replaces main-product. {%- endcomment -%}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- assign product_form_id = 'mehr-product-form-' | append: section.id -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<section
  class="mehr-pdp"
  id="MehrPDP-{{ section.id }}"
  data-section-id="{{ section.id }}"
  style="
    --mehr-bg: {{ section.settings.bg_color | default: '#FAFAF7' }};
    --mehr-ink: {{ section.settings.ink_color | default: '#0F0F0E' }};
    --mehr-muted: #6B6B66;
    --mehr-line: #E8E6DF;
    --mehr-accent: {{ section.settings.accent_color | default: '#DCE94B' }};
    --mehr-product: {{ section.settings.product_color | default: '#1E3A8A' }};
    --mehr-product-hero: {{ section.settings.product_hero_color | default: '#DCE7F5' }};
    --mehr-price: {{ section.settings.product_color | default: '#1E3A8A' }};
    --mehr-success: #2F7A3E;
    --mehr-success-soft: #E8F3DD;
  "
>

  {%- if section.settings.show_announcement -%}
    <div class="mehr-announcement">
      <div class="mehr-announcement__inner">
        {%- if section.settings.announcement_chip != blank -%}
          <span class="mehr-chip">{{ section.settings.announcement_chip }}</span>
        {%- endif -%}
        <span class="mehr-announcement__text">{{ section.settings.announcement_text }}</span>
        <span aria-hidden="true">→</span>
      </div>
    </div>
  {%- endif -%}

  <div class="mehr-product">
    <div class="mehr-product__media">
      {%- if product.media.size > 0 -%}
        <div class="mehr-gallery" data-mehr-gallery>
          <div class="mehr-gallery__track">
            {%- for media in product.media -%}
              <div class="mehr-gallery__slide{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}">
                <img
                  src="{{ media.preview_image | image_url: width: 1200 }}"
                  srcset="{{ media.preview_image | image_url: width: 600 }} 600w, {{ media.preview_image | image_url: width: 1000 }} 1000w, {{ media.preview_image | image_url: width: 1400 }} 1400w"
                  sizes="(min-width: 1024px) 50vw, 100vw"
                  alt="{{ media.alt | default: product.title | escape }}"
                  width="1200"
                  height="1200"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                >
              </div>
            {%- endfor -%}
          </div>
          {%- if product.media.size > 1 -%}
            <div class="mehr-gallery__dots" aria-hidden="true">
              {%- for media in product.media -%}
                <span class="mehr-gallery__dot{% if forloop.first %} is-active{% endif %}"></span>
              {%- endfor -%}
            </div>
            <div class="mehr-gallery__thumbs">
              {%- for media in product.media -%}
                <button type="button" class="mehr-gallery__thumb{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}">
                  <img src="{{ media.preview_image | image_url: width: 160 }}" alt="" width="80" height="80" loading="lazy">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="mehr-product__placeholder">
          <span>{{ product.title }}</span>
        </div>
      {%- endif -%}
    </div>

    <div class="mehr-product__info">

      {%- if section.settings.show_rating -%}
        <div class="mehr-rating">
          <div class="mehr-rating__stars" aria-label="{{ section.settings.rating_value }} out of 5 stars">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>
            {%- endfor -%}
          </div>
          <span class="mehr-rating__text">{{ section.settings.rating_text }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.kicker != blank -%}
        <p class="mehr-kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}

      <h1 class="mehr-headline">
        {{- section.settings.headline | default: product.title -}}
      </h1>

      {%- if section.settings.subtagline != blank -%}
        <p class="mehr-subtagline">{{ section.settings.subtagline }}</p>
      {%- endif -%}

      <div class="mehr-supporting">
        {%- if section.settings.supporting_copy != blank -%}
          {{ section.settings.supporting_copy }}
        {%- else -%}
          {{ product.description }}
        {%- endif -%}
      </div>

      {%- if section.settings.supports_text != blank -%}
        <p class="mehr-supports">
          <span class="mehr-supports__label">Supports:</span>
          <span class="mehr-supports__value">{{ section.settings.supports_text }}</span>
        </p>
      {%- endif -%}

      <div class="mehr-trustpills">
        <span class="mehr-trustpill">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M10 3v6l-5 9a2 2 0 0 0 1.8 3h10.4a2 2 0 0 0 1.8-3l-5-9V3"/></svg>
          Third-Party Tested
        </span>
        <span class="mehr-trustpill">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>
          Clinically Studied
        </span>
        <span class="mehr-trustpill">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c4 5 6 8 6 11a6 6 0 0 1-12 0c0-3 2-6 6-11z"/></svg>
          99.9% Purity
        </span>
      </div>

      <product-form
        class="mehr-form"
        data-section-id="{{ section.id }}"
      >
        <div class="product-form__error-message-wrapper" role="alert" hidden>
          <span class="product-form__error-message"></span>
        </div>

        {%- form 'product',
          product,
          id: product_form_id,
          class: 'form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <input
            type="hidden"
            name="id"
            value="{{ current_variant.id }}"
            class="product-variant-id"
            {% if current_variant.available == false %}disabled{% endif %}
          >
          <input
            type="hidden"
            name="quantity"
            value="1"
            class="mehr-quantity-input"
          >

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                <div class="mehr-app-block" {{ block.shopify_attributes }}>
                  {% render block %}
                </div>
            {%- endcase -%}
          {%- endfor -%}

          <div class="mehr-options" role="radiogroup" aria-label="Purchase options">
            <label class="mehr-option" data-quantity="1" data-option="once">
              <input type="radio" name="mehr_purchase_option" value="once" class="mehr-option__radio">
              <span class="mehr-option__radio-visual" aria-hidden="true"></span>
              <span class="mehr-option__content">
                <span class="mehr-option__title-row">
                  <span class="mehr-option__title">Buy Once</span>
                  <span class="mehr-option__price">{{ current_variant.price | money }}</span>
                </span>
                {%- if section.settings.once_subtitle != blank -%}
                  <span class="mehr-option__subtitle">{{ section.settings.once_subtitle }}</span>
                {%- endif -%}
              </span>
            </label>

            {%- if section.settings.show_subscribe -%}
              <label class="mehr-option mehr-option--selected" data-quantity="1" data-option="subscribe">
                <input type="radio" name="mehr_purchase_option" value="subscribe" class="mehr-option__radio" checked>
                <span class="mehr-option__radio-visual" aria-hidden="true"></span>
                <span class="mehr-option__content">
                  <span class="mehr-option__title-row">
                    <span class="mehr-option__title-with-chip">
                      <span class="mehr-option__title">Subscribe</span>
                      {%- if section.settings.subscribe_chip != blank -%}
                        <span class="mehr-chip mehr-chip--success">{{ section.settings.subscribe_chip }}</span>
                      {%- endif -%}
                    </span>
                    <span class="mehr-option__price">
                      {%- if section.settings.subscribe_price != blank -%}
                        <span class="mehr-price--sale">{{ section.settings.subscribe_price }}</span>
                      {%- endif -%}
                      <span class="mehr-price--compare">{{ current_variant.price | money }}</span>
                    </span>
                  </span>
                  {%- if section.settings.subscribe_subtitle != blank -%}
                    <span class="mehr-option__subtitle">{{ section.settings.subscribe_subtitle }}</span>
                  {%- endif -%}
                </span>
              </label>
            {%- endif -%}

            {%- if section.settings.show_bundle -%}
              <label class="mehr-option mehr-option--bundle" data-quantity="{{ section.settings.bundle_quantity | default: 3 }}" data-option="bundle">
                <input type="radio" name="mehr_purchase_option" value="bundle" class="mehr-option__radio">
                <span class="mehr-option__radio-visual" aria-hidden="true"></span>
                <span class="mehr-option__content">
                  <span class="mehr-option__title-row">
                    <span class="mehr-option__title-with-chip">
                      <span class="mehr-option__title">{{ section.settings.bundle_title | default: 'Buy 2 Get 1 Free' }}</span>
                      {%- if section.settings.bundle_chip != blank -%}
                        <span class="mehr-chip mehr-chip--best-value">{{ section.settings.bundle_chip }}</span>
                      {%- endif -%}
                    </span>
                  </span>
                  {%- if section.settings.bundle_subtitle != blank -%}
                    <span class="mehr-option__subtitle">{{ section.settings.bundle_subtitle }}</span>
                  {%- endif -%}
                </span>
              </label>
            {%- endif -%}
          </div>

          <div class="product-form__buttons mehr-submit-wrap">
            <button
              type="submit"
              name="add"
              class="mehr-submit product-form__submit button button--full-width button--primary"
              data-add-to-cart
              {% if current_variant.available == false %}disabled{% endif %}
            >
              <span class="mehr-submit__label">
                {%- if current_variant.available == false -%}
                  Sold Out
                {%- else -%}
                  {{ section.settings.submit_text | default: 'Add to Cart' }}
                {%- endif -%}
              </span>
              <div class="loading__spinner hidden">
                <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                  <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                </svg>
              </div>
            </button>
          </div>

          {%- if section.settings.shipping_note != blank -%}
            <p class="mehr-shipping-note">{{ section.settings.shipping_note }}</p>
          {%- endif -%}
        {%- endform -%}
      </product-form>
    </div>
  </div>

  <section class="mehr-section mehr-trustband-sec">
    <div class="mehr-container">
      <div class="mehr-trustband">
        <div class="mehr-trustband__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>
          <p>Clinically studied peptide</p>
        </div>
        <div class="mehr-trustband__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M10 3v6l-5 9a2 2 0 0 0 1.8 3h10.4a2 2 0 0 0 1.8-3l-5-9V3"/></svg>
          <p>Third-party tested</p>
        </div>
        <div class="mehr-trustband__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c4 5 6 8 6 11a6 6 0 0 1-12 0c0-3 2-6 6-11z"/></svg>
          <p>No fillers, ever</p>
        </div>
        <div class="mehr-trustband__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h13v10H3zM16 10h4l1 3v4h-5"/><circle cx="7" cy="18" r="1.6"/><circle cx="18" cy="18" r="1.6"/></svg>
          <p>Free U.S. shipping</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mehr-section mehr-stats-sec">
    <div class="mehr-container mehr-stats">
      <div class="mehr-stat"><span class="mehr-stat__num">99.9%</span><span class="mehr-stat__label">Peptide purity</span></div>
      <div class="mehr-stat"><span class="mehr-stat__num">500<span class="mehr-stat__num-sm">mcg</span></span><span class="mehr-stat__label">Per capsule</span></div>
      <div class="mehr-stat"><span class="mehr-stat__num">2</span><span class="mehr-stat__label">Ingredients, nothing else</span></div>
      <div class="mehr-stat"><span class="mehr-stat__num">4.83<span class="mehr-stat__num-sm">/5</span></span><span class="mehr-stat__label">16,434 customers</span></div>
    </div>
  </section>

  {%- assign ingredient_blocks = section.blocks | where: 'type', 'ingredient' -%}
  {%- if ingredient_blocks.size > 0 -%}
    <section class="mehr-section mehr-section--inside">
      <div class="mehr-container">
        {%- if section.settings.inside_kicker != blank -%}
          <p class="mehr-section__kicker">{{ section.settings.inside_kicker }}</p>
        {%- endif -%}
        <h2 class="mehr-section__title">{{ section.settings.inside_title | default: 'Inside Every Bottle' }}</h2>
        <div class="mehr-ingredients">
          {%- for block in ingredient_blocks -%}
            <div class="mehr-ingredient" {{ block.shopify_attributes }}>
              <div class="mehr-ingredient__icon" style="background: {{ block.settings.tile_color | default: '#1E3A8A' }}; color: {{ block.settings.tile_text_color | default: '#fff' }};">
                <div class="mehr-ingredient__icon-inner">
                  <span class="mehr-ingredient__icon-label">{{ block.settings.tile_label }}</span>
                  {%- if block.settings.tile_sublabel != blank -%}
                    <span class="mehr-ingredient__icon-sub">{{ block.settings.tile_sublabel }}</span>
                  {%- endif -%}
                </div>
              </div>
              <div class="mehr-ingredient__body">
                <h3 class="mehr-ingredient__title">{{ block.settings.title }}</h3>
                {%- if block.settings.spec != blank -%}
                  <p class="mehr-ingredient__spec">{{ block.settings.spec }}</p>
                {%- endif -%}
                <p class="mehr-ingredient__copy">{{ block.settings.copy }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="mehr-section mehr-howto-sec">
    <div class="mehr-container mehr-container--narrow">
      <p class="mehr-section__kicker">One capsule. Every day.</p>
      <h2 class="mehr-section__title">How to take it</h2>
      <ol class="mehr-howto">
        <li class="mehr-howto__step"><span class="mehr-howto__num">1</span><div class="mehr-howto__text"><h3>Take one capsule daily</h3><p>Swallow one MEHR capsule with water. Morning is ideal, but any consistent time works.</p></div></li>
        <li class="mehr-howto__step"><span class="mehr-howto__num">2</span><div class="mehr-howto__text"><h3>No timing tricks</h3><p>It won't break a fast and doesn't need food. Take it whenever you'll actually remember it.</p></div></li>
        <li class="mehr-howto__step"><span class="mehr-howto__num">3</span><div class="mehr-howto__text"><h3>Stay consistent</h3><p>Repair compounds over time. Most people run a full 60–90 day cycle — subscribe so you never miss a day.</p></div></li>
      </ol>
    </div>
  </section>

  {%- assign effect_blocks = section.blocks | where: 'type', 'effect' -%}
  {%- if effect_blocks.size > 0 -%}
    <section class="mehr-section mehr-section--timeline" style="background: {{ section.settings.timeline_bg | default: '#F1EFE8' }};">
      <div class="mehr-container">
        {%- if section.settings.timeline_kicker != blank -%}
          <p class="mehr-section__kicker mehr-section__kicker--centered">{{ section.settings.timeline_kicker }}</p>
        {%- endif -%}
        {%- if section.settings.timeline_title != blank -%}
          <h2 class="mehr-section__title mehr-section__title--centered">{{ section.settings.timeline_title }}</h2>
        {%- endif -%}
        <div class="mehr-timeline">
          {%- for block in effect_blocks -%}
            <div class="mehr-timeline__item" {{ block.shopify_attributes }}>
              <div class="mehr-timeline__dot"></div>
              <h3 class="mehr-timeline__title">{{ block.settings.title }}</h3>
              <p class="mehr-timeline__copy">{{ block.settings.copy }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="mehr-section mehr-nolist-sec">
    <div class="mehr-container mehr-container--narrow">
      <p class="mehr-section__kicker">What you won't find</p>
      <h2 class="mehr-section__title">Our 'No' list</h2>
      <ul class="mehr-nolist">
        <li>No magnesium stearate</li>
        <li>No silicon dioxide</li>
        <li>No fillers or flow agents</li>
        <li>No proprietary blends</li>
        <li>No sugar, calories, or sweeteners</li>
        <li>No needles or refrigeration</li>
      </ul>
    </div>
  </section>

  <section class="mehr-section mehr-doc-sec">
    <div class="mehr-container mehr-container--narrow">
      <div class="mehr-doc">
        <span class="mehr-doc__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v5a4 4 0 0 0 8 0V3"/><path d="M9 12v3a5 5 0 0 0 10 0v-2"/><circle cx="19" cy="11" r="2"/></svg></span>
        <p class="mehr-doc__kicker">Researched, not hyped</p>
        <h3 class="mehr-doc__title">Built on the published BPC-157 research</h3>
        <p class="mehr-doc__body">MEHR's arginine-salt formulation is designed around peer-reviewed research on oral BPC-157 stability and absorption. Every batch is third-party tested for purity and identity — a certificate of analysis is available on request.</p>
      </div>
    </div>
  </section>

  {%- assign faq_blocks = section.blocks | where: 'type', 'faq' -%}
  {%- if faq_blocks.size > 0 -%}
    <section class="mehr-section mehr-section--faq">
      <div class="mehr-container mehr-container--narrow">
        <h2 class="mehr-section__title">{{ section.settings.faq_title | default: 'FAQs' }}</h2>
        <div class="mehr-faq">
          {%- for block in faq_blocks -%}
            <details class="mehr-faq__item" {{ block.shopify_attributes }}>
              <summary class="mehr-faq__question">
                <span>{{ block.settings.question }}</span>
                <span class="mehr-faq__icon" aria-hidden="true">+</span>
              </summary>
              <div class="mehr-faq__answer">{{ block.settings.answer }}</div>
            </details>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
  {%- if review_blocks.size > 0 -%}
    <section class="mehr-section mehr-section--reviews">
      <div class="mehr-container mehr-container--narrow">
        {%- if section.settings.reviews_title != blank -%}
          <h2 class="mehr-section__title mehr-section__title--centered">{{ section.settings.reviews_title }}</h2>
        {%- endif -%}
        <div class="mehr-reviews__summary">
          <div class="mehr-reviews__score">{{ section.settings.rating_value | default: '4.83' }}<span>/5</span></div>
          <div class="mehr-reviews__meta">
            <div class="mehr-rating__stars" aria-hidden="true">{%- for i in (1..5) -%}<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>{%- endfor -%}</div>
            <p>{{ section.settings.rating_text }}</p>
          </div>
        </div>
        <div class="mehr-reviews">
          {%- for block in review_blocks -%}
            <article class="mehr-review" {{ block.shopify_attributes }}>
              <div class="mehr-review__stars" aria-hidden="true">{%- for i in (1..5) -%}<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>{%- endfor -%}</div>
              <h4 class="mehr-review__title">{{ block.settings.title }}</h4>
              <p class="mehr-review__body">{{ block.settings.body }}</p>
              {%- if block.settings.benefits != blank -%}
                <p class="mehr-review__benefits">Noticed: <strong>{{ block.settings.benefits }}</strong></p>
              {%- endif -%}
              <div class="mehr-review__head">
                <span class="mehr-review__name">{{ block.settings.name }}</span>
                {%- if block.settings.verified -%}
                  <span class="mehr-review__verified">✓ Verified Buyer</span>
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

</section>

<script>
(function(){
  function init(g){
    var slides = g.querySelectorAll('.mehr-gallery__slide');
    var thumbs = g.querySelectorAll('.mehr-gallery__thumb');
    var dots = g.querySelectorAll('.mehr-gallery__dot');
    var track = g.querySelector('.mehr-gallery__track');
    function setActive(i){
      slides.forEach(function(s, x){ s.classList.toggle('is-active', x === i); });
      thumbs.forEach(function(t, x){ t.classList.toggle('is-active', x === i); });
      dots.forEach(function(d, x){ d.classList.toggle('is-active', x === i); });
    }
    thumbs.forEach(function(t, i){
      t.addEventListener('click', function(){
        setActive(i);
        if (track && window.matchMedia('(min-width: 1024px)').matches === false) {
          track.scrollTo({ left: i * track.clientWidth, behavior: 'smooth' });
        }
      });
    });
    if (track){
      var tmo;
      track.addEventListener('scroll', function(){
        clearTimeout(tmo);
        tmo = setTimeout(function(){
          var i = Math.round(track.scrollLeft / track.clientWidth);
          dots.forEach(function(d, x){ d.classList.toggle('is-active', x === i); });
        }, 60);
      });
    }
  }
  function boot(){ document.querySelectorAll('.mehr-gallery').forEach(init); }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else { boot(); }
  document.addEventListener('shopify:section:load', boot);
})();
</script>

