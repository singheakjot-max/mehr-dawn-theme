{% comment %}
  ==========================================================================
  MEHR PDP — Custom product section
  ==========================================================================
  WIRES:
  - Add to cart: Shopify {% form 'product' %} → POSTs to /cart/add via Dawn's
    product-form.js (already loaded by theme — handles AJAX, cart drawer, errors)
  - Variants: Dawn's snippets/product-variant-picker.liquid
  - Price: real product.price + product.compare_at_price (uses Dawn's price snippet)
  - Subscription: @app block slot (Kaching Subscriptions renders here)
  - Bundle quantity: hidden quantity input set by JS based on selected bundle
  - Cart drawer auto-opens on add (cart_type setting = drawer)

  HOW IT WORKS:
  - User clicks bundle option (Buy Once / Subscribe / Bundle) → JS sets
    quantity input to 1, 1, or 3 respectively
  - User clicks Add to Cart → form submits with variant + quantity
  - If Subscribe selected → Kaching's app block injects selling_plan param into form
  - Kaching's cart-level rules apply discounts based on quantity in cart

  CSS/JS: scoped under .mehr-pdp class — won't collide with Dawn base.css
  ==========================================================================
{% endcomment %}

{{ 'mehr-pdp.css' | asset_url | stylesheet_tag }}
<script src="{{ 'mehr-pdp.js' | asset_url }}" defer="defer"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- assign product_form_id = 'mehr-product-form-' | append: section.id -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<section
  class="mehr-pdp"
  id="MehrPDP-{{ section.id }}"
  data-section-id="{{ section.id }}"
  style="
    --mehr-bg: {{ section.settings.bg_color | default: '#FAFAF7' }};
    --mehr-ink: {{ section.settings.ink_color | default: '#0F0F0E' }};
    --mehr-muted: #6B6B66;
    --mehr-line: #E8E6DF;
    --mehr-accent: {{ section.settings.accent_color | default: '#DCE94B' }};
    --mehr-product: {{ section.settings.product_color | default: '#1E3A8A' }};
    --mehr-product-hero: {{ section.settings.product_hero_color | default: '#DCE7F5' }};
    --mehr-price: {{ section.settings.product_color | default: '#1E3A8A' }};
    --mehr-success: #2F7A3E;
    --mehr-success-soft: #E8F3DD;
  "
>

  {% comment %} ==================== ANNOUNCEMENT BAR ==================== {% endcomment %}
  {%- if section.settings.show_announcement -%}
    <div class="mehr-announcement">
      <div class="mehr-announcement__inner">
        {%- if section.settings.announcement_chip != blank -%}
          <span class="mehr-chip">{{ section.settings.announcement_chip }}</span>
        {%- endif -%}
        <span class="mehr-announcement__text">{{ section.settings.announcement_text }}</span>
        <span aria-hidden="true">→</span>
      </div>
    </div>
  {%- endif -%}

  {% comment %} ==================== PRODUCT HERO ==================== {% endcomment %}
  <div class="mehr-product">
    {% comment %} ----- Media (left) ----- {% endcomment %}
    <div class="mehr-product__media">
      <div class="mehr-product__media-inner">
        {%- if product.featured_media != blank -%}
          {%- for media in product.media limit: 1 -%}
            {{ media | image_url: width: 1200 | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              widths: '400, 600, 800, 1200',
              sizes: '(min-width: 1024px) 50vw, 100vw',
              alt: media.alt | default: product.title | escape,
              class: 'mehr-product__image'
            }}
          {%- endfor -%}
        {%- else -%}
          {% comment %} placeholder if no image uploaded yet {% endcomment %}
          <div class="mehr-product__placeholder">
            <span>{{ product.title }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>

    {% comment %} ----- Buy box (right) ----- {% endcomment %}
    <div class="mehr-product__info">

      {% comment %} Star rating row (manual settings; replace with reviews app block later) {% endcomment %}
      {%- if section.settings.show_rating -%}
        <div class="mehr-rating">
          <div class="mehr-rating__stars" aria-label="{{ section.settings.rating_value }} out of 5 stars">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>
            {%- endfor -%}
          </div>
          <span class="mehr-rating__text">{{ section.settings.rating_text }}</span>
        </div>
      {%- endif -%}

      {% comment %} Italic kicker {% endcomment %}
      {%- if section.settings.kicker != blank -%}
        <p class="mehr-kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}

      {% comment %} Main headline — uses product.title by default but overridable {% endcomment %}
      <h1 class="mehr-headline">
        {{- section.settings.headline | default: product.title -}}
      </h1>

      {% comment %} Sub-tagline (italic) {% endcomment %}
      {%- if section.settings.subtagline != blank -%}
        <p class="mehr-subtagline">{{ section.settings.subtagline }}</p>
      {%- endif -%}

      {% comment %} Supporting copy — uses product.description by default {% endcomment %}
      <div class="mehr-supporting">
        {%- if section.settings.supporting_copy != blank -%}
          {{ section.settings.supporting_copy }}
        {%- else -%}
          {{ product.description }}
        {%- endif -%}
      </div>

      {% comment %} "Supports" line {% endcomment %}
      {%- if section.settings.supports_text != blank -%}
        <p class="mehr-supports">
          <span class="mehr-supports__label">Supports:</span>
          <span class="mehr-supports__value">{{ section.settings.supports_text }}</span>
        </p>
      {%- endif -%}

      {% comment %} Optional clinical study button {% endcomment %}
      {%- if section.settings.study_link != blank -%}
        <a href="{{ section.settings.study_link }}" class="mehr-pill-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h7v16H4zM13 4h7v16h-7z" stroke="currentColor" stroke-width="1.5"/></svg>
          {{ section.settings.study_text | default: 'See The Research' }}
        </a>
      {%- endif -%}

      {% comment %} ============== BUY FORM ============== {% endcomment %}
      <product-form
        class="mehr-form"
        data-section-id="{{ section.id }}"
      >
        <div class="product-form__error-message-wrapper" role="alert" hidden>
          <span class="svg-wrapper">
            {{- 'icon-error.svg' | inline_asset_content -}}
          </span>
          <span class="product-form__error-message"></span>
        </div>

        {%- form 'product',
          product,
          id: product_form_id,
          class: 'form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          {% comment %} Variant ID — selected variant goes here {% endcomment %}
          <input
            type="hidden"
            name="id"
            value="{{ current_variant.id }}"
            class="product-variant-id"
            {% if current_variant.available == false %}disabled{% endif %}
          >

          {% comment %} Quantity — JS updates this based on selected bundle option {% endcomment %}
          <input
            type="hidden"
            name="quantity"
            value="1"
            class="mehr-quantity-input"
            data-default-quantity="1"
          >

          {% comment %} Variant picker — only renders if product has multiple variants {% endcomment %}
          {%- unless product.has_only_default_variant -%}
            <div class="mehr-variants">
              {% render 'product-variant-picker',
                product: product,
                block: section,
                product_form_id: product_form_id
              %}
            </div>
          {%- endunless -%}

          {% comment %} ============== APP BLOCKS (Kaching Subscriptions renders here) ============== {% endcomment %}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                <div class="mehr-app-block" {{ block.shopify_attributes }}>
                  {% render block %}
                </div>
            {%- endcase -%}
          {%- endfor -%}

          {% comment %} ============== BUNDLE / PURCHASE OPTIONS ============== {% endcomment %}
          <div class="mehr-options" role="radiogroup" aria-label="Purchase options">

            {% comment %} Option 1: Buy Once {% endcomment %}
            <label class="mehr-option" data-quantity="1" data-option="once">
              <input type="radio" name="mehr_purchase_option" value="once" class="mehr-option__radio">
              <span class="mehr-option__radio-visual" aria-hidden="true"></span>
              <span class="mehr-option__content">
                <span class="mehr-option__title-row">
                  <span class="mehr-option__title">Buy Once</span>
                  <span class="mehr-option__price">
                    {% render 'price', product: product, use_variant: true, price_class: 'mehr-price' %}
                  </span>
                </span>
                {%- if section.settings.once_subtitle != blank -%}
                  <span class="mehr-option__subtitle">{{ section.settings.once_subtitle }}</span>
                {%- endif -%}
              </span>
            </label>

            {% comment %} Option 2: Subscribe — pre-selected by default {% endcomment %}
            {%- if section.settings.show_subscribe -%}
              <label class="mehr-option mehr-option--selected" data-quantity="1" data-option="subscribe">
                <input type="radio" name="mehr_purchase_option" value="subscribe" class="mehr-option__radio" checked>
                <span class="mehr-option__radio-visual" aria-hidden="true"></span>
                <span class="mehr-option__content">
                  <span class="mehr-option__title-row">
                    <span class="mehr-option__title-with-chip">
                      <span class="mehr-option__title">Subscribe</span>
                      {%- if section.settings.subscribe_chip != blank -%}
                        <span class="mehr-chip mehr-chip--success">{{ section.settings.subscribe_chip }}</span>
                      {%- endif -%}
                    </span>
                    <span class="mehr-option__price">
                      {%- if section.settings.subscribe_price != blank -%}
                        <span class="mehr-price--sale">{{ section.settings.subscribe_price }}</span>
                      {%- endif -%}
                      {%- if current_variant.compare_at_price > current_variant.price -%}
                        <span class="mehr-price--compare">{{ current_variant.compare_at_price | money }}</span>
                      {%- else -%}
                        <span class="mehr-price--compare">{{ current_variant.price | money }}</span>
                      {%- endif -%}
                    </span>
                  </span>
                  {%- if section.settings.subscribe_subtitle != blank -%}
                    <span class="mehr-option__subtitle">{{ section.settings.subscribe_subtitle }}</span>
                  {%- endif -%}
                  <span class="mehr-option__benefits">
                    {%- if section.settings.subscribe_benefit_1 != blank -%}
                      <span class="mehr-option__benefit">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7" stroke="currentColor" stroke-width="1.5"/></svg>
                        {{ section.settings.subscribe_benefit_1 }}
                      </span>
                    {%- endif -%}
                    {%- if section.settings.subscribe_benefit_2 != blank -%}
                      <span class="mehr-option__benefit">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12l4 4L19 6" stroke="currentColor" stroke-width="1.5"/></svg>
                        {{ section.settings.subscribe_benefit_2 }}
                      </span>
                    {%- endif -%}
                  </span>
                </span>
              </label>
            {%- endif -%}

            {% comment %} Option 3: Bundle (buy multiple at once) {% endcomment %}
            {%- if section.settings.show_bundle -%}
              <label class="mehr-option mehr-option--bundle" data-quantity="{{ section.settings.bundle_quantity | default: 3 }}" data-option="bundle">
                <input type="radio" name="mehr_purchase_option" value="bundle" class="mehr-option__radio">
                <span class="mehr-option__radio-visual" aria-hidden="true"></span>
                <span class="mehr-option__content">
                  <span class="mehr-option__title-row">
                    <span class="mehr-option__title-with-chip">
                      <span class="mehr-option__title">{{ section.settings.bundle_title | default: 'Buy 2 Get 1 Free — 90 Day Care' }}</span>
                      {%- if section.settings.bundle_chip != blank -%}
                        <span class="mehr-chip mehr-chip--best-value">{{ section.settings.bundle_chip }}</span>
                      {%- endif -%}
                    </span>
                  </span>
                  {%- if section.settings.bundle_subtitle != blank -%}
                    <span class="mehr-option__subtitle">{{ section.settings.bundle_subtitle }}</span>
                  {%- endif -%}
                  {%- if section.settings.bundle_perk != blank -%}
                    <span class="mehr-option__perk">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12l4 4L19 6" stroke="currentColor" stroke-width="1.5"/></svg>
                      {{ section.settings.bundle_perk }}
                    </span>
                  {%- endif -%}
                </span>
              </label>
            {%- endif -%}
          </div>

          {% comment %} ============== SUBMIT BUTTON ============== {% endcomment %}
          <div class="product-form__buttons mehr-submit-wrap">
            <button
              id="ProductSubmitButton-{{ section.id }}"
              type="submit"
              name="add"
              class="mehr-submit product-form__submit"
              {% if current_variant.available == false %}disabled{% endif %}
            >
              <span class="mehr-submit__label">
                {%- if current_variant == null -%}
                  {{ 'products.product.unavailable' | t }}
                {%- elsif current_variant.available == false -%}
                  {{ 'products.product.sold_out' | t }}
                {%- else -%}
                  {{ section.settings.submit_text | default: 'Add to Cart' }}
                {%- endif -%}
              </span>
              <span class="mehr-submit__price-display">
                <span class="mehr-submit__price-now"></span>
                <span class="mehr-submit__price-was"></span>
              </span>
              {%- render 'loading-spinner' -%}
            </button>
          </div>

          {%- if section.settings.shipping_note != blank -%}
            <p class="mehr-shipping-note">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 7h11l3 4h4v6h-2a2 2 0 1 1-4 0H9a2 2 0 1 1-4 0H3z" stroke="currentColor" stroke-width="1.5"/></svg>
              {{ section.settings.shipping_note }}
            </p>
          {%- endif -%}
        {%- endform -%}
      </product-form>
    </div>
  </div>

  {% comment %} ==================== INSIDE EVERY BOTTLE ==================== {% endcomment %}
  {%- assign ingredient_blocks = section.blocks | where: 'type', 'ingredient' -%}
  {%- if ingredient_blocks.size > 0 -%}
    <section class="mehr-section mehr-section--inside">
      <div class="mehr-container">
        {%- if section.settings.inside_kicker != blank -%}
          <p class="mehr-section__kicker">{{ section.settings.inside_kicker }}</p>
        {%- endif -%}
        <h2 class="mehr-section__title">{{ section.settings.inside_title | default: 'Inside Every Bottle' }}</h2>

        <div class="mehr-ingredients">
          {%- for block in ingredient_blocks -%}
            <div class="mehr-ingredient" {{ block.shopify_attributes }}>
              <div class="mehr-ingredient__icon" style="background: {{ block.settings.tile_color | default: 'var(--mehr-product)' }}; color: {{ block.settings.tile_text_color | default: '#fff' }};">
                <div class="mehr-ingredient__icon-inner">
                  <span class="mehr-ingredient__icon-label">{{ block.settings.tile_label }}</span>
                  {%- if block.settings.tile_sublabel != blank -%}
                    <span class="mehr-ingredient__icon-sub">{{ block.settings.tile_sublabel }}</span>
                  {%- endif -%}
                </div>
              </div>
              <div class="mehr-ingredient__body">
                <h3 class="mehr-ingredient__title">{{ block.settings.title }}</h3>
                {%- if block.settings.spec != blank -%}
                  <p class="mehr-ingredient__spec">{{ block.settings.spec }}</p>
                {%- endif -%}
                <p class="mehr-ingredient__copy">{{ block.settings.copy }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {% comment %} ==================== TRUST BAR ==================== {% endcomment %}
  {%- assign trust_blocks = section.blocks | where: 'type', 'trust_item' -%}
  {%- if trust_blocks.size > 0 -%}
    <section class="mehr-section mehr-section--trust">
      <div class="mehr-container">
        <div class="mehr-trust">
          {%- for block in trust_blocks -%}
            <div class="mehr-trust__item" {{ block.shopify_attributes }}>
              <div class="mehr-trust__icon">
                {%- case block.settings.icon -%}
                  {%- when 'star' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 2l2.5 5 5.5.8-4 4 1 5.5L12 14.8 7 17.3l1-5.5-4-4 5.5-.8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                  {%- when 'lab' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><rect x="6" y="3" width="12" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 8h6M9 12h6M9 16h3" stroke="currentColor" stroke-width="1.5"/></svg>
                  {%- when 'usa' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" stroke="currentColor" stroke-width="1.5"/></svg>
                  {%- when 'check' -%}
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/></svg>
                {%- endcase -%}
              </div>
              <p class="mehr-trust__label">{{ block.settings.label }}</p>
              {%- if block.settings.link_text != blank -%}
                <a href="{{ block.settings.link_url | default: '#' }}" class="mehr-trust__link">{{ block.settings.link_text }}</a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {% comment %} ==================== TIMELINE (Body's Own Repair Compound) ==================== {% endcomment %}
  {%- assign effect_blocks = section.blocks | where: 'type', 'effect' -%}
  {%- if effect_blocks.size > 0 or section.settings.timeline_title != blank -%}
    <section class="mehr-section mehr-section--timeline" style="background: {{ section.settings.timeline_bg | default: '#F1EFE8' }};">
      <div class="mehr-container">
        {%- if section.settings.timeline_kicker != blank -%}
          <p class="mehr-section__kicker mehr-section__kicker--centered">{{ section.settings.timeline_kicker }}</p>
        {%- endif -%}
        {%- if section.settings.timeline_title != blank -%}
          <h2 class="mehr-section__title mehr-section__title--centered mehr-section__title--xl">{{ section.settings.timeline_title }}</h2>
        {%- endif -%}
        {%- if section.settings.timeline_intro != blank -%}
          <div class="mehr-section__intro">{{ section.settings.timeline_intro }}</div>
        {%- endif -%}

        {%- if effect_blocks.size > 0 -%}
          <div class="mehr-timeline">
            {%- for block in effect_blocks -%}
              <div class="mehr-timeline__item" {{ block.shopify_attributes }}>
                <div class="mehr-timeline__dot"></div>
                <h3 class="mehr-timeline__title">{{ block.settings.title }}</h3>
                <p class="mehr-timeline__copy">{{ block.settings.copy }}</p>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {% comment %} ==================== FAQ ==================== {% endcomment %}
  {%- assign faq_blocks = section.blocks | where: 'type', 'faq' -%}
  {%- if faq_blocks.size > 0 -%}
    <section class="mehr-section mehr-section--faq">
      <div class="mehr-container mehr-container--narrow">
        <h2 class="mehr-section__title">{{ section.settings.faq_title | default: 'FAQs' }}</h2>
        <div class="mehr-faq">
          {%- for block in faq_blocks -%}
            <details class="mehr-faq__item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
              <summary class="mehr-faq__question">
                <span>{{ block.settings.question }}</span>
                <span class="mehr-faq__icon" aria-hidden="true">+</span>
              </summary>
              <div class="mehr-faq__answer">{{ block.settings.answer }}</div>
            </details>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {% comment %} ==================== REVIEW CARDS (hardcoded until reviews app added) ==================== {% endcomment %}
  {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
  {%- if review_blocks.size > 0 -%}
    <section class="mehr-section mehr-section--reviews">
      <div class="mehr-container mehr-container--narrow">
        {%- if section.settings.reviews_title != blank -%}
          <h2 class="mehr-section__title">{{ section.settings.reviews_title }}</h2>
        {%- endif -%}
        <div class="mehr-reviews">
          {%- for block in review_blocks -%}
            <article class="mehr-review" {{ block.shopify_attributes }}>
              <div class="mehr-review__head">
                <span class="mehr-review__name">{{ block.settings.name }}</span>
                {%- if block.settings.verified -%}
                  <span class="mehr-review__verified">✓ Verified Buyer</span>
                {%- endif -%}
              </div>
              {%- if block.settings.benefits != blank -%}
                <p class="mehr-review__benefits">
                  <span class="mehr-review__benefits-label">Benefits Noticed:</span>
                  <span class="mehr-review__benefits-value">{{ block.settings.benefits }}</span>
                </p>
              {%- endif -%}
              <div class="mehr-review__rating-row">
                <div class="mehr-review__stars" aria-label="5 stars">
                  {%- for i in (1..5) -%}<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>{%- endfor -%}
                </div>
                {%- if block.settings.timestamp != blank -%}
                  <span class="mehr-review__time">{{ block.settings.timestamp }}</span>
                {%- endif -%}
              </div>
              <h4 class="mehr-review__title">{{ block.settings.title }}</h4>
              <p class="mehr-review__body">{{ block.settings.body }}</p>
            </article>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

</section>

{% comment %} ==================== SCHEMA ==================== {% endcomment %}
{% schema %}
{
  "name": "MEHR PDP",
  "tag": "section",
  "class": "section-mehr-pdp",
  "settings": [
    {
      "type": "header",
      "content": "🎨 Brand Colors"
    },
    {
      "type": "color",
      "id": "product_color",
      "label": "Product accent color (used for pricing, hero, bottle)",
      "default": "#1E3A8A",
      "info": "Each SKU gets its own — blue for BPC-157, red for Nattokinase, etc."
    },
    {
      "type": "color",
      "id": "product_hero_color",
      "label": "Hero background color (soft tint of product color)",
      "default": "#DCE7F5"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Page background",
      "default": "#FAFAF7"
    },
    {
      "type": "color",
      "id": "ink_color",
      "label": "Body text",
      "default": "#0F0F0E"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Lime accent (announcement bar)",
      "default": "#DCE94B"
    },
    {
      "type": "header",
      "content": "📢 Announcement Bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
